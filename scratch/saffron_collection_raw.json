      "body_html": "<style>\n  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }\n\n  body {\n    font-family: 'Jost', sans-serif;\n    background: #fdf9f0;\n    color: #1c1c1c;\n    line-height: 1.75;\n    padding: 48px 24px;\n    max-width: 800px;\n    margin: 0 auto;\n  }\n\n  .brand-label {\n    font-size: 11px;\n    letter-spacing: 3px;\n    text-transform: uppercase;\n    color: #b8902a;\n    font-weight: 600;\n    margin-bottom: 10px;\n  }\n\n  .product-eyebrow {\n    font-family: 'Cormorant Garamond', serif;\n    font-size: 14px;\n    font-style: italic;\n    color: #9a7830;\n    letter-spacing: 1px;\n    margin-bottom: 8px;\n  }\n\n  h1 {\n    font-family: 'Cormorant Garamond', serif;\n    font-size: clamp(30px, 5.5vw, 56px);\n    font-weight: 600;\n    color: #1a0c00;\n    line-height: 1.08;\n    margin-bottom: 12px;\n  }\n\n  .product-descriptor {\n    font-family: 'Cormorant Garamond', serif;\n    font-size: 17px;\n    font-style: italic;\n    color: #9a7830;\n    margin-bottom: 20px;\n  }\n\n  /* ── PILLARS ── */\n  .pillars {\n    display: flex;\n    gap: 8px;\n    flex-wrap: wrap;\n    margin-bottom: 20px;\n  }\n  .pillar {\n    font-size: 11px;\n    font-weight: 600;\n    letter-spacing: 2px;\n    text-transform: uppercase;\n    color: #1a0c00;\n    border: 1.5px solid #c9a84c;\n    padding: 5px 16px;\n    border-radius: 2px;\n  }\n\n  /* ── META ROW ── */\n  .meta-row {\n    display: flex;\n    gap: 10px;\n    flex-wrap: wrap;\n    margin-bottom: 32px;\n  }\n  .meta-tag {\n    display: inline-flex;\n    align-items: center;\n    gap: 7px;\n    background: #fff4e0;\n    border: 1px solid #e8c97a;\n    color: #7a4f00;\n    font-size: 12px;\n    font-weight: 600;\n    letter-spacing: 1px;\n    text-transform: uppercase;\n    padding: 6px 16px;\n    border-radius: 3px;\n  }\n  .meta-tag.dark {\n    background: #1a0c00;\n    border-color: #1a0c00;\n    color: #e2c47a;\n  }\n\n  /* ── INTRO ── */\n  .intro {\n    font-size: 15.5px;\n    color: #3a3a3a;\n    line-height: 1.95;\n    margin-bottom: 40px;\n    padding-left: 18px;\n    border-left: 3px solid #c9a84c;\n  }\n\n  h2 {\n    font-family: 'Cormorant Garamond', serif;\n    font-size: 26px;\n    font-weight: 600;\n    color: #1a0c00;\n    margin: 44px 0 16px;\n    padding-bottom: 10px;\n    border-bottom: 1px solid #e8dfc8;\n  }\n\n  /* ── SAFFRON FULL HERO ── */\n  .saffron-full {\n    background: linear-gradient(160deg, #1a0c00 0%, #2e1600 40%, #3d2408 70%, #2a1400 100%);\n    border-radius: 10px;\n    padding: 44px 36px;\n    position: relative;\n    overflow: hidden;\n  }\n  .saffron-full::before {\n    content: '';\n    position: absolute;\n    top: -80px; right: -80px;\n    width: 300px; height: 300px;\n    border: 1px solid rgba(201,168,76,0.12);\n    border-radius: 50%;\n  }\n  .saffron-full::after {\n    content: '';\n    position: absolute;\n    bottom: -60px; left: -60px;\n    width: 220px; height: 220px;\n    border: 1px solid rgba(201,168,76,0.08);\n    border-radius: 50%;\n  }\n  .saffron-full-label {\n    font-size: 10px;\n    letter-spacing: 3px;\n    text-transform: uppercase;\n    color: rgba(201,168,76,0.65);\n    font-weight: 600;\n    margin-bottom: 14px;\n    position: relative; z-index: 2;\n    display: flex;\n    align-items: center;\n    gap: 10px;\n  }\n  .saffron-full-label::after {\n    content: '';\n    flex: 1;\n    height: 1px;\n    background: rgba(201,168,76,0.2);\n  }\n  .saffron-full h3 {\n    font-family: 'Cormorant Garamond', serif;\n    font-size: clamp(22px, 3.5vw, 34px);\n    font-weight: 600;\n    color: #e2c47a;\n    line-height: 1.2;\n    margin-bottom: 18px;\n    position: relative; z-index: 2;\n  }\n  .saffron-full p {\n    font-size: 15px;\n    color: rgba(255,255,255,0.82);\n    line-height: 1.92;\n    position: relative; z-index: 2;\n    max-width: 640px;\n    margin-bottom: 14px;\n  }\n  .saffron-compounds {\n    display: grid;\n    grid-template-columns: repeat(3, 1fr);\n    gap: 12px;\n    margin-top: 28px;\n    position: relative; z-index: 2;\n  }\n  .compound-card {\n    background: rgba(201,168,76,0.08);\n    border: 1px solid rgba(201,168,76,0.2);\n    border-radius: 5px;\n    padding: 18px 16px;\n    text-align: center;\n  }\n  .compound-name {\n    font-family: 'Cormorant Garamond', serif;\n    font-size: 21px;\n    font-weight: 600;\n    color: #e2c47a;\n    margin-bottom: 6px;\n  }\n  .compound-role {\n    font-size: 11px;\n    color: rgba(255,255,255,0.5);\n    line-height: 1.5;\n    letter-spacing: 0.5px;\n  }\n  .saffron-origin-strip {\n    display: flex;\n    gap: 0;\n    margin-top: 28px;\n    border-top: 1px solid rgba(201,168,76,0.18);\n    padding-top: 22px;\n    position: relative; z-index: 2;\n    flex-wrap: wrap;\n  }\n  .origin-item {\n    flex: 1;\n    min-width: 120px;\n    padding-right: 20px;\n  }\n  .origin-item:not(:last-child) {\n    border-right: 1px solid rgba(201,168,76,0.15);\n    margin-right: 20px;\n  }\n  .origin-label {\n    font-size: 10px;\n    letter-spacing: 2px;\n    text-transform: uppercase;\n    color: rgba(201,168,76,0.55);\n    font-weight: 600;\n    margin-bottom: 5px;\n  }\n  .origin-value {\n    font-family: 'Cormorant Garamond', serif;\n    font-size: 15px;\n    color: #e2c47a;\n    font-weight: 500;\n    line-height: 1.4;\n  }\n\n  /* ── BENEFITS ── */\n  .benefits-list { list-style: none; }\n  .benefits-list li {\n    display: flex;\n    align-items: flex-start;\n    gap: 18px;\n    padding: 18px 0;\n    border-bottom: 1px solid #ede6d4;\n    font-size: 14.5px;\n    color: #3a3a3a;\n    line-height: 1.78;\n  }\n  .benefits-list li:last-child { border-bottom: none; }\n  .benefit-icon {\n    width: 40px; height: 40px;\n    background: #fff4e0;\n    border: 1px solid #e8c97a;\n    border-radius: 50%;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    font-size: 18px;\n    flex-shrink: 0;\n    margin-top: 2px;\n  }\n  .benefit-text b {\n    display: block;\n    color: #1a0c00;\n    font-size: 14px;\n    font-weight: 600;\n    margin-bottom: 4px;\n  }\n\n  /* ── INGREDIENT CARDS ── */\n  .ingredient-card {\n    background: #fff;\n    border: 1px solid #e8dfc8;\n    border-radius: 6px;\n    overflow: hidden;\n    margin-bottom: 14px;\n  }\n  .ingredient-header {\n    display: flex;\n    align-items: center;\n    gap: 16px;\n    padding: 20px 24px;\n    background: #1a0c00;\n  }\n  .ingredient-card.star .ingredient-header {\n    background: linear-gradient(135deg, #1a0c00 0%, #3d2408 100%);\n  }\n  .ingredient-card.star .ingredient-header::after {\n    content: '★ Hero Ingredient';\n    font-size: 10px;\n    letter-spacing: 2px;\n    text-transform: uppercase;\n    color: rgba(201,168,76,0.85);\n    font-weight: 700;\n    margin-left: auto;\n    white-space: nowrap;\n    flex-shrink: 0;\n  }\n  .ingredient-num {\n    font-family: 'Cormorant Garamond', serif;\n    font-size: 36px;\n    font-weight: 300;\n    color: rgba(201,168,76,0.4);\n    line-height: 1;\n    min-width: 36px;\n  }\n  .ingredient-title-wrap h3 {\n    font-family: 'Cormorant Garamond', serif;\n    font-size: 20px;\n    font-weight: 600;\n    color: #e2c47a;\n    margin-bottom: 3px;\n    line-height: 1.2;\n  }\n  .ingredient-title-wrap span {\n    font-size: 11px;\n    letter-spacing: 1.5px;\n    text-transform: uppercase;\n    color: rgba(255,255,255,0.4);\n    font-weight: 500;\n  }\n  .ingredient-body {\n    padding: 20px 24px;\n    font-size: 14px;\n    color: #4a4a4a;\n    line-height: 1.82;\n  }\n  .ingredient-body b { color: #1a0c00; }\n  .action-tags {\n    display: flex;\n    flex-wrap: wrap;\n    gap: 6px;\n    margin-top: 12px;\n  }\n  .action-tag {\n    font-size: 11px;\n    letter-spacing: 1px;\n    font-weight: 600;\n    text-transform: uppercase;\n    color: #7a4f00;\n    background: #fff8ee;\n    border: 1px solid #e8c97a;\n    padding: 3px 10px;\n    border-radius: 2px;\n  }\n\n  /* ── RESULTS TABLE ── */\n  table { width: 100%; border-collapse: collapse;