      "body_html": "<p><meta charset=\"UTF-8\"> <meta content=\"width=device-width, initial-scale=1.0\" name=\"viewport\"><meta content=\"Saffron Protective Sunscreen SPF 50+ by Kashmir Online Store. Lightweight natural sunscreen with Kashmiri Saffron extract, Zinc Oxide and Vitamin E. Protects from sun damage, prevents tanning and maintains radiance. 100% natural. No synthetic additives.\" name=\"description\"> <link rel=\"stylesheet\" href=\"https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400;1,600&amp;family=Jost:wght@300;400;500;600&amp;display=swap\"></p>\n<style>\n  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }\n\n  body {\n    font-family: 'Jost', sans-serif;\n    background: #faf8f3;\n    color: #1c1c1c;\n    line-height: 1.75;\n    padding: 48px 24px;\n    max-width: 800px;\n    margin: 0 auto;\n  }\n\n  .brand-label {\n    font-size: 11px;\n    letter-spacing: 3px;\n    text-transform: uppercase;\n    color: #b8902a;\n    font-weight: 600;\n    margin-bottom: 10px;\n  }\n\n  .product-eyebrow {\n    font-family: 'Cormorant Garamond', serif;\n    font-size: 14px;\n    font-style: italic;\n    color: #9a7a3a;\n    letter-spacing: 1px;\n    margin-bottom: 8px;\n  }\n\n  h1 {\n    font-family: 'Cormorant Garamond', serif;\n    font-size: clamp(30px, 5vw, 52px);\n    font-weight: 600;\n    color: #1a1000;\n    line-height: 1.1;\n    margin-bottom: 12px;\n  }\n\n  .product-descriptor {\n    font-family: 'Cormorant Garamond', serif;\n    font-size: 17px;\n    font-style: italic;\n    color: #8a6820;\n    margin-bottom: 20px;\n  }\n\n  /* ── SPF BADGE ── */\n  .spf-badge-row {\n    display: flex;\n    align-items: center;\n    gap: 10px;\n    flex-wrap: wrap;\n    margin-bottom: 22px;\n  }\n  .spf-badge {\n    background: #1a1000;\n    color: #e2c47a;\n    font-family: 'Cormorant Garamond', serif;\n    font-size: 28px;\n    font-weight: 600;\n    padding: 10px 22px;\n    border-radius: 4px;\n    letter-spacing: 1px;\n    line-height: 1;\n  }\n  .spf-badge sup { font-size: 14px; vertical-align: super; }\n  .spf-sub {\n    font-size: 12px;\n    letter-spacing: 1.5px;\n    text-transform: uppercase;\n    color: #7a7a7a;\n    font-weight: 600;\n    line-height: 1.5;\n  }\n\n  /* ── PILLARS ── */\n  .pillars {\n    display: flex;\n    gap: 8px;\n    flex-wrap: wrap;\n    margin-bottom: 20px;\n  }\n  .pillar {\n    font-size: 11px;\n    font-weight: 600;\n    letter-spacing: 2px;\n    text-transform: uppercase;\n    color: #1a1000;\n    border: 1.5px solid #c9a84c;\n    padding: 5px 16px;\n    border-radius: 2px;\n  }\n\n  /* ── META ROW ── */\n  .meta-row {\n    display: flex;\n    gap: 10px;\n    flex-wrap: wrap;\n    margin-bottom: 32px;\n  }\n  .meta-tag {\n    display: inline-flex;\n    align-items: center;\n    gap: 7px;\n    background: #fff4e0;\n    border: 1px solid #e8c97a;\n    color: #7a4f00;\n    font-size: 12px;\n    font-weight: 600;\n    letter-spacing: 1px;\n    text-transform: uppercase;\n    padding: 6px 16px;\n    border-radius: 3px;\n  }\n  .meta-tag.dark {\n    background: #1a1000;\n    border-color: #1a1000;\n    color: #e2c47a;\n  }\n  .meta-tag.green {\n    background: #edf5e8;\n    border-color: #a0c878;\n    color: #2d5a0f;\n  }\n\n  /* ── INTRO ── */\n  .intro {\n    font-size: 15.5px;\n    color: #3a3a3a;\n    line-height: 1.95;\n    margin-bottom: 40px;\n    padding-left: 18px;\n    border-left: 3px solid #c9a84c;\n  }\n\n  h2 {\n    font-family: 'Cormorant Garamond', serif;\n    font-size: 26px;\n    font-weight: 600;\n    color: #1a1000;\n    margin: 44px 0 16px;\n    padding-bottom: 10px;\n    border-bottom: 1px solid #e8dfc8;\n  }\n\n  /* ── SAFFRON HERO ── */\n  .saffron-hero {\n    background: linear-gradient(135deg, #1a1000 0%, #2e1a00 55%, #3d2a08 100%);\n    border-radius: 8px;\n    padding: 34px 32px;\n    position: relative;\n    overflow: hidden;\n    margin-bottom: 8px;\n  }\n  .saffron-hero::before {\n    content: '';\n    position: absolute;\n    top: -60px; right: -60px;\n    width: 220px; height: 220px;\n    border: 1px solid rgba(201,168,76,0.15);\n    border-radius: 50%;\n  }\n  .saffron-hero::after {\n    content: '';\n    position: absolute;\n    bottom: -40px; left: -40px;\n    width: 160px; height: 160px;\n    border: 1px solid rgba(201,168,76,0.1);\n    border-radius: 50%;\n  }\n  .saffron-hero-label {\n    font-size: 10px;\n    letter-spacing: 3px;\n    text-transform: uppercase;\n    color: rgba(201,168,76,0.7);\n    font-weight: 600;\n    margin-bottom: 12px;\n    position: relative; z-index: 2;\n  }\n  .saffron-hero h3 {\n    font-family: 'Cormorant Garamond', serif;\n    font-size: clamp(20px, 3vw, 28px);\n    font-weight: 600;\n    color: #e2c47a;\n    line-height: 1.25;\n    margin-bottom: 14px;\n    position: relative; z-index: 2;\n  }\n  .saffron-hero p {\n    font-size: 14.5px;\n    color: rgba(255,255,255,0.82);\n    line-height: 1.9;\n    position: relative; z-index: 2;\n    max-width: 620px;\n  }\n  .saffron-facts {\n    display: flex;\n    gap: 0;\n    margin-top: 26px;\n    border-top: 1px solid rgba(201,168,76,0.2);\n    padding-top: 22px;\n    position: relative; z-index: 2;\n    flex-wrap: wrap;\n  }\n  .saffron-fact {\n    flex: 1;\n    min-width: 130px;\n    padding-right: 20px;\n  }\n  .saffron-fact:not(:last-child) {\n    border-right: 1px solid rgba(201,168,76,0.15);\n    margin-right: 20px;\n  }\n  .saffron-fact-label {\n    font-size: 10px;\n    letter-spacing: 2px;\n    text-transform: uppercase;\n    color: rgba(201,168,76,0.6);\n    font-weight: 600;\n    margin-bottom: 5px;\n  }\n  .saffron-fact-value {\n    font-family: 'Cormorant Garamond', serif;\n    font-size: 15px;\n    color: #e2c47a;\n    font-weight: 500;\n    line-height: 1.4;\n  }\n\n  /* ── PROTECTION STATS ── */\n  .protection-row {\n    display: grid;\n    grid-template-columns: repeat(3, 1fr);\n    gap: 12px;\n    margin-top: 4px;\n  }\n  .protection-card {\n    backgroun